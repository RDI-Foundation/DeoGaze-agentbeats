{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/rkstu/entropic-crmarena-green:latest",
    entrypoint: [
      "uv",
      "run",
      "src/server.py",
      "--host",
      "0.0.0.0",
      "--port",
      "8081"
    ],
    env: {
      OPENAI_API_KEY: "${config.openai_api_key}",
      NEBIUS_API_KEY: "${config.nebius_api_key}",
      PROXY_URL: "${slots.proxy.url}",
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8081 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
      nebius_api_key: { type: "string", secret: true }
    },
    required: ["openai_api_key", "nebius_api_key"],
    additionalProperties: false,
  },
  slots: {
    proxy: { kind: "a2a" },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: {
    a2a: "a2a",
  },
  metadata: {
    assessment_config: {
      "task_limit": 3,
      "drift_level": "none",
      "rot_level": "none",
      "max_steps": 7,
      "timeout": 300,
      "org_type": "b2c",
    },
    participant_roles: ["agent"]
  }
}
